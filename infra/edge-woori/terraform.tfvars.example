aws_region  = "ap-northeast-2"
project     = "woori-wallet"
service     = "woori"
environment = "prd"
name_prefix = "woori-wallet-prd"

state_bucket_name = "woori-wallet-tfstate-655700895912-apne2"

node_port                  = 30081
target_group_name          = "woori-backend-prd-tg"
alb_host_header            = "woori.internal"
alb_listener_rule_priority = 110
blocked_paths              = ["/metrics", "/metrics/*"]
health_check_path          = "/api/health"
health_check_matcher       = "200-399"

api_throttling_burst_limit = 100
api_throttling_rate_limit  = 50

custom_domain_name = "woori-api.dannis.cloud"
route53_zone_name  = "dannis.cloud"
# jwt_issuer   = "https://issuer.example.com"
# jwt_audience = ["woori-api"]

tags = {}
